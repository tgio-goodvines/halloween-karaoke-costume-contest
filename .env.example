HALLOWEEN_APP_SECRET=<flask-session-secret>
HALLOWEEN_ADMIN_PASSWORD=<admin-password>
HALLOWEEN_REDIS_HOST=127.0.0.1
HALLOWEEN_REDIS_PORT=6379
HALLOWEEN_REDIS_DB=1
HALLOWEEN_REDIS_USERNAME=<local-redis-acl-user>
HALLOWEEN_REDIS_PASSWORD=<local-redis-acl-password>
HALLOWEEN_REDIS_PREFIX=halloween
HALLOWEEN_REDIS_URL=redis://<local-redis-acl-user>:<local-redis-acl-password>@127.0.0.1:6379/1
HALLOWEEN_DISPLAY_WIFI_NETWORK="Halloween Party WiFi"
HALLOWEEN_DISPLAY_WIFI_PASSWORD=halloween
HALLOWEEN_EMAIL_UPDATES_ENABLED=false
HALLOWEEN_SES_REGION=us-east-1
HALLOWEEN_EMAIL_FROM="Qiana and Tony's Halloween Party <no-reply@tnq-halloween.com>"
HALLOWEEN_PUBLIC_BASE_URL=https://tnq-halloween.com
